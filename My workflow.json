      "parameters": {
        "jsCode": "// Input comes from the HTTP node\nconst data = $json;\n\n// Safety check\nif (!data || !data.states) {\n  return [{ flights: [] }];\n}\n\nconst states = data.states;\nconst flights = [];\n\nfor (const s of states) {\n  const flight = {\n    icao24: s[0],\n    callsign: (s[1] || \"\").trim(),\n    origin_country: s[2],\n    time_position: s[3],\n    last_contact: s[4],\n    longitude: s[5],\n    latitude: s[6],\n    baro_altitude: s[7],\n    on_ground: s[8],\n    velocity_mps: s[9],\n    true_track_deg: s[10],\n    vertical_rate_mps: s[11],\n    geo_altitude: s[13],\n    squawk: s[14],\n    spi: s[15],\n    position_source: s[16],\n  };\n  flights.push(flight);\n}\n\nreturn [{ flights }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
