      "parameters": {
        "jsCode": "// In \"Run Once for All Items\" mode, input is an array of items\nlet flights = [];\n\nif (items.length > 0 && items[0].binary && items[0].binary.fileContent) {\n    const binData = items[0].binary.fileContent.data; // Base64-encoded\n    const fileText = Buffer.from(binData, 'base64').toString('utf8');\n    try {\n        flights = JSON.parse(fileText);\n    } catch (err) {\n        console.error(\"Error parsing JSON:\", err);\n    }\n}\n\nreturn [\n    {\n        json: { flights }\n    }\n];\n"
